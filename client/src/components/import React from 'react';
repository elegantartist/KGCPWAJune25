import React from 'react';
import { useConnectivity } from '@/hooks/useConnectivity';
import { Wifi, WifiOff } from 'lucide-react';
import { cn } from '@/lib/utils';

/**
 * A non-intrusive banner that displays the current network connectivity status.
 * It only appears when the connection is limited or offline.
 */
export const ConnectivityBanner: React.FC = () => {
  const { isOffline, isMinimal } = useConnectivity();

  // Don't render the banner if the connection is good (functional or full)
  if (!isOffline && !isMinimal) {
    return null;
  }

  const message = isOffline
    ? "You are currently offline. Some features may be unavailable."
    : "Your connection is limited. Performance may be affected.";

  const icon = isOffline ? <WifiOff size={16} /> : <Wifi size={16} />;

  return (
    <div
      className={cn(
        'w-full p-2 text-center text-sm text-white flex items-center justify-center gap-2',
        isOffline ? 'bg-destructive' : 'bg-amber-500'
      )}
      role="alert"
    >
      {icon}
      <span>{message}</span>
    </div>
  );
};